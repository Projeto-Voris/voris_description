<?xml version="1.0"?>
<robot name="bluerov2_heavy">

  <!-- Define some properties -->

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>



  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.5707"/>
      <geometry>
        <mesh filename="package://voris_description/urdf/meshes/bluerov2_heavy_skid.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <!-- Link 1 -->
  <link name="left_camera_link">
    <visual>
      <geometry>
        <cylinder radius="0.01" length="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- Joint connecting base_link to link_1 -->
  <joint name="left_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_camera_link"/>
    <origin xyz="0.19 0.075 0.201" rpy="0 0 0"/>
  </joint>

  <!-- Rotated left_camera_frame -->
  <link name="left_camera_frame">
  </link>

  <!-- Joint connecting left_camera_link and left_camera_frame-->
  <joint name="left_link_to_frame_joint" type="fixed">
    <parent link="left_camera_link"/>
    <child link="left_camera_frame"/>
    <origin xyz="0 0 0" rpy="-1.5707 0 -1.5707"/>
  </joint>

  <!-- Link 2 -->
  <link name="right_camera_link">
    <visual>
      <geometry>
        <cylinder radius="0.01" length="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- Joint connecting link_1 to link_2 -->
  <joint name="right_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_camera_link"/>
    <origin xyz="0.19 -0.075 0.201" rpy="0 0 0"/>
  </joint>

  <!-- Rotated right_camera_frame -->
  <link name="right_camera_frame">
  </link>

  <!-- Joint connecting left_camera_link and left_camera_frame-->
  <joint name="right_link_to_frame_joint" type="fixed">
    <parent link="right_camera_link"/>
    <child link="right_camera_frame"/>
    <origin xyz="0 0 0" rpy="-1.5707 0 -1.5707"/>
  </joint>

</robot>
