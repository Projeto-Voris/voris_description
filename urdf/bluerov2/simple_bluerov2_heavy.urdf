<?xml version="1.0"?>
<robot name="bluerov2_heavy">
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>



  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.1"/>
      </geometry>
      <material name="black"/>
<!--      <color rgba="0.5 0.5 0.5 1"/>-->
    </visual>
  </link>

  <!-- Link 1 -->
  <link name="left_camera_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="blue"/>
<!--      <color rgba="0 0 1 1"/>-->
    </visual>
  </link>

  <!-- Joint connecting base_link to link_1 -->
  <joint name="left_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_camera_link"/>
    <origin xyz="0.19 0.075 0.201" rpy="-1.57 0 -1.57"/>
  </joint>

  <!-- Link 2 -->
  <link name="right_camera_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="blue"/>
<!--      <color rgba="0 0 1 1"/>-->
    </visual>
  </link>

  <!-- Joint connecting link_1 to link_2 -->
  <joint name="right_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_camera_link"/>
    <origin xyz="0.19 -0.075 0.201" rpy="-1.57 0 -1.57"/>
  </joint>

  <link name="thruster1_link">
    <visual>
<!--      <origin xyz="0 0 0" rpy="1.57 0 0"/>-->
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <!--      <material name="blue"/>-->
      <!--      <color rgba="0 0 1 1"/>-->
    </visual>
  </link>

  <joint name="thruster1_joint" type="continuous">
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="thruster1_link"/>
    <origin xyz="0.138 -0.098 -0.0137" rpy="-1.570 1.570 -0.785"/>
  </joint>

</robot>
