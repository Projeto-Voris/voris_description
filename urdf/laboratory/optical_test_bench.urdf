<?xml version="1.0"?>
<robot name="optical_bench">

  <!-- URDF for optical table bench from laboratory-->

  <!-- Define some properties -->

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>



  <!-- Base Link -->
  <link name="base_link">
  </link>
  
  <!-- SM4  -->
    <joint name="base_joint" type="fixed">
      <parent link="base_link"/>
      <child link="SM4/base_link"/>
      <!-- <origin xyz="-0.1 -0.45 0" rpy="0 0 0"/> -->
      <origin xyz="-0 0 0.2" rpy="0 0 0"/>
    </joint>

    <link name="SM4/base_link">
      <visual>
        <!-- <origin xyz="0 0 -0.01" rpy="1.5707 0 0"/> -->
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <!-- <cylinder radius="0.01" length="0.35"/> -->
          <box size="0.045 0.52 0.045"/>
        </geometry>
        <!-- <material name="red"/> -->
        <material name="black"/>
      </visual>
    </link>

    <!-- Joint connecting base_link to link_1 -->
        <joint name="left_base_joint" type="fixed">
      <parent link="SM4/base_link"/>
      <child link="left_base_link"/>
      <origin xyz="0 0.2825 -0.0775" rpy="0 0 0"/> <!---"-1.5707 0 -1.7467" -->
    </joint>
    <!-- Joint connecting link_1 to link_2 -->
    <joint name="right_base_joint" type="fixed">
      <parent link="SM4/base_link"/>
      <child link="right_base_link"/>
      <origin xyz="0 -0.2825 -0.0775" rpy="0 0 0"/> <!---"-1.5707 0 -1.3947" -->
    </joint>

    <!-- Link 1 -->
    <link name="left_base_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5707 0 0"/>
        <geometry>
          <box size="0.045 0.245 0.045"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <!-- Link 2 -->
    <link name="right_base_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5707 0 0"/>
        <geometry>
          <box size="0.045 0.245 0.045"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <!-- camera left -->
        <link name="SM4/left_camera_link">
        <visual>
            <geometry>
            <cylinder radius="0.01" length="0.05"/>
            </geometry>
            <material name="blue"/>
        </visual>
        </link>
        <!-- camera right -->
        <link name="SM4/right_camera_link">
        <visual>
            <geometry>
            <cylinder radius="0.01" length="0.05"/>
            </geometry>
            <material name="blue"/>
        </visual>
        </link>

        <joint name="SM4/left_camera_joint" type="fixed">
            <parent link="SM4/base_link"/>
            <child link="SM4/left_camera_link"/>
            <origin xyz="0 0.15 0.0325" rpy="-1.5707 0 -1.5707"/>
        </joint>

        <joint name="SM4/right_camera_joint" type="fixed">
            <parent link="SM4/base_link"/>
            <child link="SM4/right_camera_link"/>
            <origin xyz="0.0 -0.15 0.0325" rpy="-1.5707 0 -1.5707"/>
        </joint>

  <!-- SM4  projector -->
      <link name='SM4/projector_link'>
        <visual>
        <origin xyz="0 0 0" rpy="1.57 0 0"/>
          <geometry>
          <box size="0.15 0.15 0.03"/>
          </geometry>
          <material name="red"/>
        </visual>
      </link>
      
      <joint name="SM4/projector_joint" type="fixed">
        <parent link="SM4/base_link"/>
        <child link="SM4/projector_link"/>
        <origin xyz="0.0 0.0 -0.0475" rpy="-1.5 0 -1.5707"/>
      </joint>

  <!-- SM3 laser -->
      <link name='SM4/laser_link'>
      <visual>
      <origin xyz="0 0.01 0" rpy="1.57 0 0"/>
          <geometry>
          <box size="0.045 0.045 0.07"/>
          </geometry>
          <material name="red"/>
      </visual>
      </link>

      <joint name="SM4/laser_joint" type="fixed">
        <parent link="SM4/base_link"/>
        <child link="SM4/laser_link"/>
        <origin xyz="0.0 0.0 0.0675" rpy="-1.5707 0 -1.5707"/>
      </joint>

  <!-- Passive -->
    <joint name="Passive/base_joint" type="fixed">
      <parent link="base_link"/>
      <child link="Passive/base_link"/>
      <origin xyz="0 0 0.295" rpy="0 0 0"/>
    </joint>

    <link name="Passive/base_link">
    <visual>
        <geometry>
        <box size="0.035 0.220 0.005"/>
        </geometry>
        <material name="black"/>
    </visual>
    </link>

    <!-- Link 1 -->
    <link name="Passive/left_camera_link">
    <visual>
        <geometry>
        <cylinder radius="0.01" length="0.05"/>
        </geometry>
        <material name="green"/>
    </visual>
    </link>

    <!-- Joint connecting base_link to link_1 -->
    <joint name="Passive/left_camera_joint" type="fixed">
      <parent link="Passive/base_link"/>
      <child link="Passive/left_camera_link"/>
      <origin xyz="0 0.1 0.0125" rpy="-1.5707 0 -1.5707"/> <!---"-1.5707 0 -1.7467" -->
    </joint>

    <!-- Link 2 -->
    <link name="Passive/right_camera_link">
    <visual>
        <geometry>
        <cylinder radius="0.01" length="0.05"/>
        </geometry>
        <material name="green"/>
    </visual>
    </link>

    <!-- Joint connecting link_1 to link_2 -->
    <joint name="Passive/right_camera_joint" type="fixed">
      <parent link="Passive/base_link"/>
      <child link="Passive/right_camera_link"/>
      <origin xyz="0.0 -0.1 0.0125" rpy="-1.5707 0 -1.5707"/> <!---"-1.5707 0 -1.3947" -->
    </joint>

</robot>
